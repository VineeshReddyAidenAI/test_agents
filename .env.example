# Copy this file to .env and fill in your key.
# The app reads these via app/config.py (pydantic-settings).

# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: model used by all agents (default below).
# Any chat model with tool-calling works (gpt-4o-mini, gpt-4o, gpt-4.1-mini, ...).
OPENAI_MODEL=gpt-4o-mini

# Optional: sampling temperature for all agents (default 0.2 — low for consistency).
OPENAI_TEMPERATURE=0.2
